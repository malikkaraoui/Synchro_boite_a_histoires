{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LuniiSync",
  "version": "2.1.2",
  "identifier": "com.luniisync.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "LuniiSync",
        "width": 760,
        "height": 620,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.icns", "icons/icon.png", "icons/icon_256.png", "icons/icon_512.png"],
    "resources": ["../lunii-bridge.py"],
    "macOS": {
      "entitlements": "../lunii-app.entitlements"
    }
  }
}
